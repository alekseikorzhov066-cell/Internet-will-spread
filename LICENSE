<body>
<div class="card">
    <div class="glitch">🛡️ СКАНЕР БЕЗОПАСНОСТИ</div>
    <div class="sub">Анализ твоего подключения и сети</div>

    <div id="info">
        <div class="row"><span class="label">Публичный IP</span><span class="value" id="publicIp">⏳</span></div>
        <div class="row"><span class="label">Локальный IP</span><span class="value" id="localIp">⏳</span></div>
        <div class="row"><span class="label">Шлюз (роутер)</span><span class="value" id="gateway">⏳</span></div>
        <div class="row"><span class="label">Браузер</span><span class="value" id="browser">⏳</span></div>
        <div class="row"><span class="label">Операционная система</span><span class="value" id="os">⏳</span></div>
        <div class="row"><span class="label">Защита</span><span class="value" id="protection">⏳</span></div>
        <div class="row"><span class="label">SSL/HTTPS</span><span class="value" id="ssl">⏳</span></div>
        <div class="row"><span class="label">User-Agent</span><span class="value" id="ua" style="font-size:12px;">⏳</span></div>
    </div>

    <button class="btn" onclick="location.reload()">🔄 Сканировать снова</button>

    <div class="scan-line">
        <span id="status">[<span class="blink">■</span>] Ожидание сканирования...</span>
    </div>

    <div class="tip" id="tip">
        <strong>💡 Совет:</strong> Используй сложные пароли, включи двухфакторную аутентификацию и обновляй прошивку роутера.
    </div>
</div>

<script>
    // ============================================================
    // НУБИК: БЕЗОПАСНЫЙ СКАНЕР (НИЧЕГО НЕ ОТПРАВЛЯЕТ)
    // ============================================================

    function log(msg) {
        document.getElementById('status').textContent = '[■] ' + msg;
    }

    function setEl(id, val) {
        document.getElementById(id).textContent = val;
    }

    log('Начинаю сканирование...');

    // --- 1. Публичный IP ---
    fetch('https://api.ipify.org?format=json')
        .then(r => r.json())
        .then(d => {
            setEl('publicIp', d.ip);
            log('Публичный IP получен');
        })
        .catch(() => {
            setEl('publicIp', '❌ Ошибка');
            log('Ошибка получения IP');
        });

    // --- 2. Локальный IP через WebRTC ---
    function getLocalIP() {
        try {
            const pc = new RTCPeerConnection({ iceServers: [] });
            pc.createDataChannel('');
            pc.createOffer().then(o => pc.setLocalDescription(o));
            pc.onicecandidate = (e) => {
                if (e.candidate) {
                    const ip = e.candidate.candidate.match(/(\d+\.\d+\.\d+\.\d+)/);
                    if (ip) {
                        setEl('localIp', ip[1]);
                        pc.close();
                        log('Локальный IP найден');
                    }
                }
            };
            setTimeout(() => {
                if (document.getElementById('localIp').textContent === '⏳') {
                    setEl('localIp', '❌ Не найден');
                }
            }, 3000);
        } catch {
            setEl('localIp', '❌ Ошибка');
        }
    }
    getLocalIP();

    // --- 3. Шлюз ---
    setEl('gateway', '192.168.0.1 (предположительно)');

    // --- 4. Браузер ---
    const ua = navigator.userAgent;
    let browser = 'Неизвестно';
    if (ua.includes('Chrome')) browser = 'Google Chrome';
    else if (ua.includes('Firefox')) browser = 'Mozilla Firefox';
    else if (ua.includes('Safari')) browser = 'Apple Safari';
    else if (ua.includes('Edge')) browser = 'Microsoft Edge';
    else if (ua.includes('Opera')) browser = 'Opera';
    setEl('browser', browser);

    // --- 5. ОС ---
    let os = 'Неизвестно';
    if (ua.includes('Windows NT 10.0')) os = 'Windows 10/11';
    else if (ua.includes('Windows NT 6.1')) os = 'Windows 7';
    else if (ua.includes('Mac OS X')) os = 'macOS';
    else if (ua.includes('Linux')) os = 'Linux';
    else if (ua.includes('Android')) os = 'Android';
    else if (ua.includes('iPhone') || ua.includes('iPad')) os = 'iOS';
    setEl('os', os);

    // --- 6. Защита ---
    const isHttps = window.location.protocol === 'https:';
    const hasDnt = navigator.doNotTrack !== null;
    let protection = '⚠️ Неизвестно';
    if (isHttps && hasDnt) protection = '✅ Хорошо (HTTPS + DNT)';
    else if (isHttps) protection = '✅ Хорошо (HTTPS)';
    else if (hasDnt) protection = '⚠️ Есть DNT, но нет HTTPS';
    else protection = '❌ Нет защиты. Используй HTTPS.';
    setEl('protection', protection);

    // --- 7. SSL ---
    setEl('ssl', isHttps ? '✅ Защищён' : '❌ Нет шифрования');

    // --- 8. User-Agent ---
    setEl('ua', ua);

    // --- 9. Совет ---
    const tips = [
        'Используй менеджер паролей, чтобы не повторять пароли.',
        'Включи двухфакторную аутентификацию везде, где можно.',
        'Обновляй прошивку роутера — это закрывает уязвимости.',
        'Не подключайся к открытым Wi-Fi без VPN.',
        'Используй только HTTPS-сайты.',
        'Регулярно проверяй, кто подключен к твоему роутеру.'
    ];
    document.getElementById('tip').innerHTML = `<strong>💡 Совет:</strong> ${tips[Math.floor(Math.random() * tips.length)]}`;

    log('✅ Сканирование завершено');
</script>
</body>
</html>
